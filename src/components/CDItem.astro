---
const { project, index } = Astro.props;
---
<div class="cd-item" tabindex="0" aria-label={project.title}>
  <div class="cd-visual">
    <img src={project.cover} alt={project.title} loading="lazy" />
    <div class="cd-label">
      <span>{project.title}</span>
      <span>{project.year}</span>
    </div>
  </div>
</div>
<!--
CDItem represents a single project CD, handles hover/click animations.
-->