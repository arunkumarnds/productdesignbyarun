---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

import CDStack from '../components/CDStack.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
					<h1>👾 Retro-Futuristic Portfolio</h1>
					<p class="intro">A curated stack of projects, presented as a tactile CD rack. Hover and click a disc to explore each project.</p>
					<CDStack />
					<p class="about-link"><a href="/about">About Arun Kumar</a> | <a href="/contact">Contact</a></p>
		</main>
		<Footer />
	</body>
</html>
