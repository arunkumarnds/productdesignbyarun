---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>👋 Hi, I'm Arun Kumar</h1>
			<p>
				I'm a passionate <strong>Product Designer</strong> with a keen eye for detail and a love for creating intuitive, delightful user experiences. My work blends creativity, empathy, and strategy to solve real-world problems and help brands grow.
			</p>
			<p>
				With years of experience in digital design, I specialize in UI/UX, interaction design, and design systems. I enjoy collaborating with cross-functional teams to turn ideas into impactful products.
			</p>
			<p>
				On this site, you'll find my portfolio, blog posts, and resources about design, creativity, and technology. Feel free to explore and connect!
			</p>
			<ul>
				<li>View my latest projects and case studies</li>
				<li>Read my thoughts on design and innovation</li>
				<li>Get in touch for collaborations or freelance work</li>
			</ul>
			<p>
				Thanks for visiting!
			</p>
		</main>
		<Footer />
	</body>
</html>
